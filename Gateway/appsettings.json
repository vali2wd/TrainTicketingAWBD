{
  "ReverseProxy": {
    "HttpRequest": {
      "Version": "1.1",
      "VersionPolicy": "RequestVersionExact"
    },
    "Routes": {
      "business-route": {
        "ClusterId": "business-cluster",
        "Match": { "Path": "/api/ticketing/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/ticketing" },
          {
            "RequestHeader": "X-Forwarded-Prefix",
            "Set": "/api/ticketing"
          }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "RateLimiterPolicy": "api-policy",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/notifications" } ]
      },
      "reporting-route": {
        "ClusterId": "reporting-cluster",
        "Match": { "Path": "/api/reports/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/reports" } ]
      }
    },
    "Clusters": {
      "business-cluster": {
        "Destinations": {
          "destination1": {
            // CHANGE THIS TO 5000 (The HTTP port from your log)
            "Address": "http://trainticketing.api:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://trainticketing.notification.api:8080/" }
        }
      },
      "reporting-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://trainticketing.reporting.api:8080/" }
        }
      }
    }
  }
}